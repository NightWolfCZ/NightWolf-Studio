---
// src/components/About.astro
---

<section id="about" class="py-24 px-4 bg-[#081426] overflow-hidden">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 md:gap-10 lg:gap-16 items-start">
    
    <div class="reveal flex flex-col items-start md:pr-10 mb-16 md:mb-0">
      <span class="text-[#D4AF37] font-mono text-xs tracking-[0.5em] uppercase mb-6 block">
        Est. 2026 / The Alpha Identity
      </span>
      
      <h2 class="text-4xl lg:text-5xl xl:text-6xl font-black text-white uppercase tracking-tighter mb-8 leading-none">
        Led by <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#D4AF37] to-[#8A6D1D]">Instinct</span>
      </h2>
      
      <div class="space-y-6 text-slate-400 text-lg leading-relaxed mb-10 max-w-xl">
        <p>
          At <strong class="text-white">Night Wolf Studio</strong>, we don't wait for the future. 
          We architect it. Every pixel and every line of code is driven by predatory 
          ambition and technological precision.
        </p>
        <p>
          I build digital ecosystems that aren't just seen—they are felt. 
          My work is designed for those who aim to dominate their territory.
        </p>
      </div>

      <div class="bg-[#0A192F] p-8 border-l-4 border-[#D4AF37] relative mb-12 group hover:bg-[#0d1f3d] transition-colors w-full max-w-xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">🐺</span>
          <h3 class="text-white font-bold tracking-widest uppercase text-sm">Elen's Manifesto</h3>
        </div>
        <blockquote class="text-slate-300 italic text-lg leading-relaxed">
          "The digital world doesn't need another copy. It needs an identity with its own pulse. 
          My mission is to drag your project out of the shadows of mediocrity and place it at 
          the top of the food chain."
        </blockquote>
      </div>

      <a href="#contact" class="inline-block px-10 py-4 bg-[#D4AF37] text-[#0A192F] font-black uppercase text-[10px] tracking-[0.3em] hover:bg-white transition-all duration-500 shadow-xl shadow-[#D4AF37]/5">
        Get Alpha Strategy
      </a>
    </div>

    <div class="relative group flex justify-center md:justify-end md:items-start pt-10 md:pt-20">
      
      <div class="absolute inset-0 border border-[#D4AF37]/10 translate-x-4 translate-y-4 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500 w-full max-w-[350px] aspect-[3/4]"></div>
      
      <div class="relative w-full max-w-[350px] aspect-[3/4] overflow-hidden bg-[#0A192F] border border-white/5 shadow-2xl">
        <img 
          src="/elen.png" 
          alt="Elen - Alpha Identity" 
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] via-transparent to-transparent opacity-60"></div>
        
        <div class="absolute bottom-12 -left-4 bg-[#D4AF37] text-[#0A192F] px-4 py-1 font-black text-[9px] tracking-[0.2em] uppercase shadow-2xl rotate-[-90deg] origin-bottom-left z-10">
            Lead Developer
        </div>
      </div>
    </div>

  </div>
</section>