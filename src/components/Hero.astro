---
// src/components/Hero.astro
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0A192F]">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#D4AF37]/5 rounded-full blur-[120px]"></div>

  <div class="relative z-10 text-center px-4">
    <div class="reveal opacity-0 transition-all duration-1000 translate-y-10" id="hero-reveal">
      <h1 class="text-[clamp(3rem,15vw,10rem)] font-black text-white leading-[0.8] tracking-tighter uppercase mb-2">
        Night Wolf
      </h1>
      
      <p class="text-[#D4AF37] font-mono text-sm md:text-xl tracking-[0.6em] uppercase mb-12 ml-[0.6em]">
        Digital Engineering Studio
      </p>

      <div class="flex flex-col items-center gap-8">
        <a href="#services" class="group relative px-12 py-5 bg-[#D4AF37] text-[#0A192F] font-bold uppercase text-[10px] tracking-[0.3em] overflow-hidden transition-all duration-300 hover:bg-white">
          <span class="relative z-10">Enter the Wolfpack</span>
          <div class="absolute inset-0 w-0 bg-white transition-all duration-300 group-hover:w-full"></div>
        </a>
        
        <div class="flex gap-8 items-center text-slate-500 text-[9px] tracking-[0.2em] uppercase font-bold">
          <span class="flex items-center gap-2"><span class="w-1 h-1 bg-[#D4AF37] rounded-full"></span> High Performance</span>
          <span class="flex items-center gap-2"><span class="w-1 h-1 bg-[#D4AF37] rounded-full"></span> Bespoke Design</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Jednoduchý trigger pro reveal animaci po načtení
  window.addEventListener('load', () => {
    const hero = document.getElementById('hero-reveal');
    if (hero) {
      hero.classList.remove('opacity-0', 'translate-y-10');
      hero.classList.add('opacity-100', 'translate-y-0');
    }
  });
</script>