---
const tiers = [
  { 
    name: "ESSENTIAL", 
    price: "$1,950",
    delivery: "7-10 business days",
    features: [
      "Modern One-Page Design",
      "High-Performance Load Speed",
      "Core SEO Optimization",
      "Contact Form Integration",
      "Vercel Deployment Included"
    ] 
  },
  { 
    name: "BUSINESS", 
    price: "$3,800",
    delivery: "14-21 business days",
    features: [
      "Multi-Page Architecture",
      "Advanced Visual Identity",
      "Deep SEO Configuration",
      "CMS for Easy Updates",
      "Social Media Ecosystem"
    ],
    featured: true 
  },
  { 
    name: "SIGNATURE", 
    price: "$7,500",
    delivery: "4-6 weeks",
    features: [
      "Bespoke AI Brand Model",
      "Premium Interactive Motion",
      "Full Strategy & Copywriting",
      "Maximum Security Shield",
      "Priority 24/7 Support"
    ] 
  }
];
---

<section id="pricing" class="py-24 px-4 bg-[#081426]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <span class="text-[#D4AF37] font-mono text-xs tracking-[0.5em] uppercase mb-4 block">Select your tier</span>
      <h2 class="text-5xl md:text-7xl font-black text-white uppercase tracking-tighter">
        Investment <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#D4AF37] to-[#8A6D1D]">Plans</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {tiers.map((t) => (
        <div class={`relative flex flex-col p-10 border transition-all duration-500 ${t.featured ? 'bg-[#0D1F3D] border-[#D4AF37] scale-105 z-10 shadow-2xl shadow-[#D4AF37]/10' : 'bg-[#0A192F] border-white/5 hover:border-[#D4AF37]/30'}`}>
          
          {t.featured && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#D4AF37] text-[#0A192F] px-4 py-1 text-[9px] font-black uppercase tracking-[0.2em]">
              Most Wanted
            </div>
          )}

          <h3 class="text-white text-2xl font-black uppercase tracking-tighter mb-2">{t.name}</h3>
          <div class="text-4xl font-light text-white mb-4">{t.price}</div>
          
          <div class="flex items-center gap-2 text-[#D4AF37] text-[10px] font-bold uppercase tracking-widest mb-8 border-y border-white/5 py-3">
            <span>⚡</span> {t.delivery}
          </div>

          <ul class="space-y-4 mb-12 flex-grow">
            {t.features.map((f) => (
              <li class="text-slate-400 text-sm flex items-start gap-3 leading-tight">
                <span class="text-[#D4AF37] font-bold">/</span> {f}
              </li>
            ))}
          </ul>

          <button 
            data-tier={t.name}
            class={`order-btn block w-full text-center py-4 font-black uppercase text-[10px] tracking-[0.3em] transition-all duration-300 ${t.featured ? 'bg-[#D4AF37] text-[#0A192F] hover:bg-white' : 'border border-white/10 text-white hover:bg-white hover:text-[#0A192F]'}`}
          >
            Claim This Tier
          </button>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.order-btn');
  
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tier = btn.getAttribute('data-tier');
      const email = "nightwolf.webstudio@gmail.com";
      const subject = encodeURIComponent(`Project Inquiry: ${tier}`);
      const body = encodeURIComponent(`Hello,\n\nI am interested in the ${tier} package. Please contact me to discuss the details.`);
      
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });
  });
</script>